{
  "name": "trading-platform",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "docker:build": "docker build -t cccat22_backend docker",
    "docker:run": "docker run -it -v $(pwd)/.:/app cccat22_backend bash",
    "compose:up": "docker compose -f docker/docker-compose.yml up -d --build",
    "compose:down": "docker compose -f docker/docker-compose.yml -v down",
    "compose:exec": "docker compose -f docker/docker-compose.yml exec -it backend bash",
    "compose:db:down": "docker compose -f docker/docker-compose.yml -v down db",
    "compose:db:up": "docker compose -f docker/docker-compose.yml up db -d",
    "typecheck": "tsc --noEmit",
    "ci:tests": "npx jest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": ""
}
